{
  "name": "medicos",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm --prefix client run dev\"",
    "dev:server": "node --watch server/index.js",
    "start": "node server/index.js",
    "install-all": "npm install && npm --prefix client install",
    "test": "node --test --test-isolation=none",
    "mock:generate": "node scripts/generate-mocks.js --with-tests"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "concurrently": "^9.0.0",
    "cors": "^2.8.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "nodemailer": "^6.9.0",
    "puppeteer": "^23.0.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "xml2js": "^0.6.0",
    "zod": "^3.23.0"
  }
}
